      #lbl(10, 28, "00"); #lbl(10, 58, "01"); #lbl(10, 88, "11"); #lbl(10, 118, "10")
      
      #lbl(48, 28, "1"); #lbl(78, 28, "1"); #lbl(108, 28, "-"); #lbl(138, 28, "0")
